[Unit]
Description=Trading Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/live-dashboard
ExecStart=/opt/live-dashboard/venv/bin/python dashboard/app.py
Restart=on-failure
RestartSec=5
Environment=DB_PATH=/opt/trades/trades.db
Environment=DASH_PORT=5050

[Install]
WantedBy=multi-user.target
